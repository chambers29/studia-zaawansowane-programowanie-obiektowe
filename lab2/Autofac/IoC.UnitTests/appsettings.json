{
  "autofac": {
    "components": [
      // <register type="ILogger" mapTo="Logger"/>
      {
        "type": "IoC.Logger, IoC",
        "services": [ { "type": "IoC.ILogger, IoC" } ]
      },
      // <register type="Worker" />
      {
        "type": "IoC.Worker, IoC"
      },
      // <register type="ILogger" mapTo="NumLogger" name="numlog">
      {
        "name": "numlog",
        "type": "IoC.NumLogger, IoC",
        "services": [ { "type": "IoC.ILogger, IoC" } ],
        "lifetime": "single-instance",
        "parameters": {
          "i": 1
        }
      },
      // <register type="MetWorker" name="numwork">
      {
        "name": "numwork",
        "type": "IoC.MetWorker, IoC",
        "properties": {
          "m_log": {
            "service": "numlog" // Wstrzyknij nazwaną usługę ILogger
          }
        }
      },
      // <instance name="inlog" type="ILogger" value="100" typeConverter="NumLogConv"/>
      {
        "name": "inlog",
        "type": "IoC.NumLogger, IoC",
        "services": [ { "type": "IoC.ILogger, IoC" } ],
        "parameters": {
          "i": 100
        }
      },
      // <register type="SetWorker" name="inwork">
      {
        "name": "inwork",
        "type": "IoC.SetWorker, IoC",
        "methods": [
          {
            "name": "SetLogger",
            "parameters": {
              "l": {
                "service": "inlog"
              }
            }
          }
        ]
      },
      // <register type="MetWorker" name="num2work">
      {
        "name": "num2work",
        "type": "IoC.MetWorker, IoC",
        "properties": {
          "m_log": {
            "service": "inlog"
          }
        }
      }
    ]
  }
}

